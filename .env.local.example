# Razorpay (Payments)
# Get these from Razorpay Dashboard > Settings > API Keys
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=...

# Supabase (Database)
# Get these from Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://xyz.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=anon_...

# Admin & Security
# Generate a long random string for ADMIN_SECRET
ADMIN_SECRET=change_this_to_a_long_random_value
# Base URL for the application (default localhost for dev)
BASE_URL=http://localhost:3000

# Optional: Email (SMTP)
# Only needed if you want to replace the default emailer
SMTP_USER=yourgmailaddress@gmail.com
SMTP_PASS=your_app_password_here
EMAIL_FROM=noreply@yourdomain.com
